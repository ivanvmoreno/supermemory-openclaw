{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"formatter": {
		"enabled": false
	},
	"assist": {
		"enabled": false
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "off"
			},
			"correctness": {
				"noUnusedVariables": "warn",
				"noUnusedImports": "warn",
				"noUnusedFunctionParameters": "warn",
				"noUnusedPrivateClassMembers": "warn"
			},
			"style": {
				"noDefaultExport": "off",
				"noNonNullAssertion": "off",
				"noParameterAssign": "off",
				"useNumberNamespace": "warn",
				"noUnusedTemplateLiteral": "warn"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/*.lock",
			"!tests/integration/longmemeval/fixtures/oracle.json"
		]
	},
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"useIgnoreFile": true
	}
}
